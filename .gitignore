# --- DÉPENDANCES ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- SÉCURITÉ & SECRETS (TRÈS IMPORTANT) ---
# Ignore toutes les variables d'environnement pour ne pas voler ta clé Gemini
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# --- NEXT.JS & BUILD ---
# Fichiers générés lors du npm run dev ou build
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# --- TESTS ---
/coverage

# --- SYSTÈME & IDE ---
# Fichiers spécifiques à Mac (ton cas) ou VS Code
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# --- LOGS & DEBUG ---
# Fichiers d'erreurs générés par npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# --- VERCEL ---
.vercel

# --- CACHE ---
.cache/